// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Work {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  type        String   // 'video' | 'image'
  category    String   // 'AI短剧' | '恋综' | '人物设计' | '场景设计' | '其他'
  tags        String   @default("[]") // JSON array stored as string
  coverImage  String
  description String
  content     String   @default("") // Markdown content
  images      String   @default("[]") // JSON array stored as string
  videoUrl    String   @default("")
  prompts     String   @default("[]") // JSON array — PromptItem[]
  workflow    String   @default("[]") // JSON array — WorkflowStep[]
  summary     String   @default("")
  sections    String   @default("[]") // JSON — WorkSection[]
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
}

model SiteConfig {
  key   String @id
  value String @default("")
}
